<Window x:Class="PrimeDictate.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:ClassModifier="internal"
        Title="PrimeDictate History"
        Width="1000"
        Height="680"
        MinWidth="840"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="{DynamicResource TextPrimaryBrush}">
    <Border Background="{DynamicResource WindowBackgroundBrush}"
            CornerRadius="12"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Background="Transparent" MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Margin="16,12,0,12"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Text="Transcript History" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,8,8,0">
                    <Button Width="32" Height="32" Content="—" Background="Transparent" BorderThickness="0" Click="OnMinimizeClick" ToolTip="Minimize" />
                    <Button Width="32" Height="32" Content="✕" Background="Transparent" BorderThickness="0" Click="OnCloseClick" ToolTip="Close" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="12,0,12,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock VerticalAlignment="Center"
                               Text="Search" />
                    <TextBox x:Name="SearchTextBox"
                             Grid.Column="1"
                             Margin="8,0,12,0"
                             MinWidth="240"
                             Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Search final and original transcript text" />
                    <TextBlock Grid.Column="2"
                               Margin="0,0,12,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="{Binding ResultSummary}" />
                    <Button Grid.Column="3"
                            Width="76"
                            Content="Clear"
                            IsEnabled="{Binding HasActiveRetrievalFilters}"
                            Click="OnClearRetrievalClick" />

                    <Grid Grid.Row="1"
                          Grid.ColumnSpan="4"
                          Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="190" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   Text="Status" />
                        <ComboBox Grid.Column="1"
                                  Margin="8,0,0,0"
                                  ItemsSource="{Binding Filters}"
                                  SelectedItem="{Binding SelectedFilter, Mode=TwoWay}" />

                        <TextBlock Grid.Column="3"
                                   VerticalAlignment="Center"
                                   Text="App" />
                        <ComboBox Grid.Column="4"
                                  Margin="8,0,0,0"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding TargetAppOptions}"
                                  SelectedItem="{Binding SelectedTargetApp, Mode=TwoWay}" />

                        <TextBlock Grid.Column="6"
                                   VerticalAlignment="Center"
                                   Text="Window" />
                        <ComboBox Grid.Column="7"
                                  Margin="8,0,0,0"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding TargetWindowOptions}"
                                  SelectedItem="{Binding SelectedTargetWindow, Mode=TwoWay}"
                                  MaxDropDownHeight="320" />
                    </Grid>
                </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="8">
                <ListBox ItemsSource="{Binding Entries}"
                         SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,6"
                                    Padding="6"
                                    BorderBrush="{StaticResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding TimestampUtc, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" />
                                    <TextBlock Margin="0,3,0,0"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="{Binding DeliveryStatus}" />
                                    <TextBlock Margin="0,3,0,0"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="{Binding TargetSummary}" />
                                    <TextBlock Margin="0,4,0,0"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               Text="{Binding Transcript}"
                                               ToolTip="{Binding Transcript}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Grid.Column="2"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Text="{Binding SelectedEntry.TimestampUtc, TargetNullValue=No history item selected, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" />

                    <StackPanel Grid.Row="1" Margin="0,8,0,10">
                        <TextBlock Text="{Binding SelectedEntry.ThreadId, StringFormat=Thread: {0}}" />
                        <TextBlock Margin="0,2,0,0"
                                   Text="{Binding SelectedEntry.DeliveryStatus, StringFormat=Delivery: {0}}" />
                        <TextBlock Margin="0,2,0,0"
                                   Text="{Binding SelectedEntry.TargetAppDisplayName, StringFormat=Target app: {0}}" />
                        <TextBlock Margin="0,2,0,0"
                                   Text="{Binding SelectedEntry.TargetWindowDisplayName, StringFormat=Target window: {0}}" />
                        <TextBlock Margin="0,2,0,0"
                                   Text="{Binding SelectedEntry.AudioDurationSeconds, StringFormat=Audio: {0:N1}s}" />
                        <TextBlock Margin="0,2,0,0"
                                   Text="{Binding SelectedEntry.Error, TargetNullValue=(none), StringFormat=Error: {0}}" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedEntry.OriginalTranscript}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock FontWeight="SemiBold" Text="Original Transcript" Margin="0,0,0,4"/>
                                <TextBox IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                                         Text="{Binding SelectedEntry.OriginalTranscript}" />
                                
                                <TextBlock FontWeight="SemiBold" Text="Ollama Context (System Prompt)" Margin="0,12,0,4"/>
                                <TextBox IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                                         Text="{Binding SelectedEntry.OllamaSystemPrompt}" />
                                         
                                <TextBlock FontWeight="SemiBold" Text="Final Injected Transcript" Margin="0,12,0,4"/>
                            </StackPanel>

                            <TextBox IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                                     Text="{Binding SelectedEntry.Transcript}" />
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="3"
                                Margin="0,10,0,0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Width="132"
                                Margin="0,0,10,0"
                                Content="Copy transcript"
                                Click="OnCopyTranscriptClick" />
                        <Button Width="150"
                                Content="Copy with metadata"
                                Click="OnCopyDetailsClick" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
    </Grid>
    </Border>
</Window>
