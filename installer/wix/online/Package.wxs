<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package
      Name="PrimeDictate"
      Language="1033"
      Manufacturer="FlowDevs.io"
      Version="$(var.ProductVersion)"
      UpgradeCode="E1F2A3B4-C5D6-4789-ABCD-EF0123456789"
      InstallerVersion="500"
      Scope="perMachine">
    <MajorUpgrade DowngradeErrorMessage="A newer version of PrimeDictate is already installed." />
    <util:QueryNativeMachine />
    <Launch
        Condition='"$(sys.BUILDARCH)" ~= "x64" IMP (NOT WIX_NATIVE_MACHINE OR WIX_NATIVE_MACHINE = 34404)'
        Message="This x64 installer is for Intel/AMD64 Windows. Use the ARM64 installer on Copilot+ PCs for native QNN/NPU support." />
    <MediaTemplate EmbedCab="yes" />
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="$(sys.SOURCEFILEDIR)..\assets\License.rtf" />
    <Property Id="LAUNCHATLOGIN" Value="1" />

    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch PrimeDictate (Ready=Blue, Recording=Red, Error=Yellow tray status)" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
    <CustomAction
        Id="SetWixShellExecTarget"
        Property="WixShellExecTarget"
        Value="[INSTALLFOLDER]PrimeDictate.exe"
        Execute="immediate" />
    <CustomAction
        Id="LaunchApplication"
        BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)"
        DllEntry="WixShellExec"
        Execute="immediate"
        Impersonate="yes"
        Return="ignore" />
    <UI>
      <Publish
          Dialog="ExitDialog"
          Control="Finish"
          Event="DoAction"
          Value="SetWixShellExecTarget"
          Order="1"
          Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed" />
      <Publish
          Dialog="ExitDialog"
          Control="Finish"
          Event="DoAction"
          Value="LaunchApplication"
          Order="2"
          Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed" />
    </UI>

    <Feature
        Id="Main"
        Title="PrimeDictate"
        Description="Installs PrimeDictate with workspace dashboard and branded tray status indicators."
        Level="1">
      <ComponentGroupRef Id="AppComponents" />
      <ComponentGroupRef Id="StartMenuShortcutComponents" />
      <ComponentGroupRef Id="LaunchAtLoginComponents" />
      <ComponentGroupRef Id="OnlineScriptComponents" />
    </Feature>

    <InstallExecuteSequence>
      <Custom Action="RunDownloadModel" After="InstallFiles" Condition="NOT REMOVE" />
    </InstallExecuteSequence>
  </Package>
</Wix>
